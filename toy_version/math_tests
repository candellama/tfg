if __name__ == '__main__':
    # 1. Cargamos las pruebas de nuestra clase
    suite_math = unittest.TestLoader().loadTestsFromTestCase(TestMath)
    unittest.TextTestRunner(verbosity=2).run(suite_math)

    # Ejecutamos todas las pruebas juntas
    suite_func = unittest.TestLoader().loadTestsFromTestCase(TestFunctional)
