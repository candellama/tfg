    # ML-DSA instance with security level 2
    ml_dsa = MLDSA(security_level=2)
    
    # Generate keypair
    public_key, private_key = ml_dsa.generate_keypair()
    
    print(f"Public Key (hex): {public_key.hex()[:64]}...")
    print(f"Public Key Size: {len(public_key)} bytes")
    print(f"Private Key Size: {len(private_key)} bytes")
